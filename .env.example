# Select provider: openai | groq | cerebras | google
AI_PROVIDER=google

# OpenAI
OPENAI_API_KEY=replace_with_openai_key
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=https://api.openai.com/v1

# Groq
GROQ_API_KEY=replace_with_groq_key
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_MODEL=openai/gpt-oss-120b
# Alternate model option:
# GROQ_MODEL=llama-3.3-70b-versatile

# Cerebras
CEREBRAS_API_KEY=replace_with_cerebras_key
CEREBRAS_BASE_URL=https://api.cerebras.ai/v1
CEREBRAS_MODEL=gpt-oss-120b

# Google (OpenAI-compatible endpoint)
GOOGLE_API_KEY=replace_with_google_key
GOOGLE_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
GOOGLE_MODEL=gemini-2.5-flash
# Alternate model option:
# GOOGLE_MODEL=gemini-2.5-flash-lite
